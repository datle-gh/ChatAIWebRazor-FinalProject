{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ChatAIWebDb;Trusted_Connection=True;TrustServerCertificate=true;Encrypt=true;"
  },
  "FileStorage": {
    "UploadRoot": "App_Data/Uploads"
  },
  "UploadSettings": {
    "MaxFileSizeMb": 100,
    "MaxFilesPerBatch": 10,
    "MaxBatchSizeMb": 500
  },
  "Embedding": {
    "Provider": "Ollama",
    "DefaultModel": "bge-m3",
    "DefaultModelKey": "bge-m3",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "bge-m3",
      "Truncate": true,
      "MaxInputCharacters": 3500,
      "MaxRetryCount": 2,
      "RetryDelayMilliseconds": 600
    },
    "PhoBert": {
      "BaseUrl": "http://localhost:8001",
      "Model": "vinai/phobert-base",
      "Enabled": false
    },
    "Models": [
      {
        "Key": "bge-m3",
        "Provider": "Ollama",
        "Model": "bge-m3",
        "BaseUrl": "http://localhost:11434",
        "Dimension": 1024,
        "Enabled": true,
        "IncludeInBenchmark": true,
        "MaxInputCharacters": 3500
      },
      {
        "Key": "phobert-base",
        "Provider": "PhoBert",
        "Model": "vinai/phobert-base",
        "BaseUrl": "http://localhost:8001",
        "Dimension": 768,
        "Enabled": true,
        "IncludeInBenchmark": true,
        "MaxInputCharacters": 2000
      },
      {
        "Key": "phobert-finetuned",
        "Provider": "PhoBert",
        "Model": "models/phobert-finetuned",
        "BaseUrl": "http://localhost:8001",
        "Dimension": 768,
        "Enabled": false,
        "IncludeInBenchmark": true,
        "MaxInputCharacters": 2000
      }
    ]
  },
  "VectorStore": {
    "Provider": "Qdrant",
    "DualWrite": true
  },
  "Qdrant": {
    "Host": "localhost",
    "Port": 6333,
    "UseHttps": false,
    "ApiKey": "",
    "CollectionPrefix": "chataiweb"
  },
  "Ragas": {
    "ServiceBaseUrl": "http://localhost:8002"
  },
  "Llm": {
    "Provider": "Gemini",
    "Model": "gemini-2.5-flash",
    "Gemini": {
      "BaseUrl": "https://generativelanguage.googleapis.com",
      "Temperature": 0.2,
      "MaxOutputTokens": 1024
    }
  },
  "RagSettings": {
    "TopK": 5,
    "SimilarityThreshold": 0.6,
    "MaxCitationSnippetLength": 250,
    "MaxContextChunks": 5,
    "MaxChunkTokens": 700,
    "ChunkOverlapTokens": 100,
    "MinChunkCharacters": 30
  }
}
