@page "/Subject/Index"
@model Presentation.Pages.Subject.IndexModel

@{
    ViewData["Title"] = "Quản lý môn học";
    Layout = "_Layout";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "primary": "#3525cd",
                    "primary-container": "#4f46e5",
                    "primary-fixed": "#e2dfff",
                    "surface-container-lowest": "#ffffff",
                    "surface-container-low": "#f2f4f6",
                    "surface-container": "#eceef0",
                    "surface-container-high": "#e6e8ea",
                    "background": "#f7f9fb",
                    "on-surface": "#191c1e",
                    "on-surface-variant": "#464555",
                    "outline-variant": "#c7c4d8",
                    "error": "#ba1a1a",
                    "error-container": "#ffdad6"
                }
            }
        }
    };
</script>

<style>
    .subject-card {
        border: 1px solid rgba(199, 196, 216, 0.2);
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.04);
        transition: box-shadow 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
    }

    .subject-card:hover {
        box-shadow: 0 8px 28px rgba(79, 70, 229, 0.18);
        transform: translateY(-3px);
        border-color: rgba(79, 70, 229, 0.35);
    }

    .avatar-initial {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-weight: 700;
    }
</style>

<div class="bg-background min-h-screen p-6 md:p-10 space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl md:text-4xl font-bold text-on-surface mb-1" style="font-family:'Be Vietnam Pro',sans-serif">
                Quản lý môn học
            </h1>
            <p class="text-on-surface-variant" style="font-family:'Inter',sans-serif">
                @(Model.ViewModel.IsAdmin ? "Quản lý môn học, giảng viên, sinh viên và danh sách tham gia." : "Danh sách môn học bạn đang tham gia.")
            </p>
        </div>
        @if (Model.ViewModel.IsAdmin)
        {
            <div class="flex flex-col sm:flex-row gap-3 sm:items-center">
                <div class="inline-flex rounded-xl border border-outline-variant/40 bg-white p-1" style="font-family:'Inter',sans-serif">
                    <a asp-page="/Subject/Index" asp-route-statusFilter="active"
                       data-subject-filter="active"
                       class="px-3 py-2 rounded-lg text-sm font-semibold @(Model.ViewModel.StatusFilter == "active" ? "text-white" : "text-on-surface-variant")"
                       style="@(Model.ViewModel.StatusFilter == "active" ? "background:#4f46e5;text-decoration:none" : "text-decoration:none")">
                        Đang hoạt động
                    </a>
                    <a asp-page="/Subject/Index" asp-route-statusFilter="deleted"
                       data-subject-filter="deleted"
                       class="px-3 py-2 rounded-lg text-sm font-semibold @(Model.ViewModel.StatusFilter == "deleted" ? "text-white" : "text-on-surface-variant")"
                       style="@(Model.ViewModel.StatusFilter == "deleted" ? "background:#4f46e5;text-decoration:none" : "text-decoration:none")">
                        Đã xóa
                    </a>
                    <a asp-page="/Subject/Index" asp-route-statusFilter="all"
                       data-subject-filter="all"
                       class="px-3 py-2 rounded-lg text-sm font-semibold @(Model.ViewModel.StatusFilter == "all" ? "text-white" : "text-on-surface-variant")"
                       style="@(Model.ViewModel.StatusFilter == "all" ? "background:#4f46e5;text-decoration:none" : "text-decoration:none")">
                        Tất cả
                    </a>
                </div>
                <a asp-page="/Subject/Create"
                   class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-white transition-all active:scale-95 shadow-sm hover:shadow-md flex-shrink-0"
                   style="background:#4f46e5;font-family:'Inter',sans-serif;text-decoration:none">
                    <span class="material-symbols-outlined text-[18px]">add</span>
                    Thêm môn học
                </a>
            </div>
        }
    </div>

    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div class="flex items-center gap-3 px-5 py-3 rounded-xl border text-sm"
             style="background:#e2dfff;border-color:#c3c0ff;color:#3525cd;font-family:'Inter',sans-serif">
            <span class="material-symbols-outlined text-[18px]">check_circle</span>
            @successMsg
        </div>
    }
    @if (TempData["ErrorMessage"] is string errorMsg)
    {
        <div class="flex items-center gap-3 px-5 py-3 rounded-xl border text-sm"
             style="background:#ffdad6;border-color:#ffb4ab;color:#ba1a1a;font-family:'Inter',sans-serif">
            <span class="material-symbols-outlined text-[18px]">error</span>
            @errorMsg
        </div>
    }
    <div id="subject-inline-message"></div>

    <div id="subject-list-region"
         data-subject-list-base-url="@Url.Page("/Subject/Index", "ListPartial")"
         data-subject-list-url="@Url.Page("/Subject/Index", "ListPartial", new { statusFilter = Model.ViewModel.StatusFilter })"
         data-status-filter="@Model.ViewModel.StatusFilter">
        @await Html.PartialAsync("_SubjectListPartial", Model.ViewModel)
    </div>

    @if (Model.ViewModel.IsAdmin)
    {
        <div id="soft-delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background:rgba(15,23,42,0.42)">
            <div class="bg-white rounded-2xl shadow-xl border border-outline-variant/40 w-full max-w-lg p-6" onclick="event.stopPropagation()">
                <h2 class="text-xl font-bold text-on-surface mb-1" style="font-family:'Be Vietnam Pro',sans-serif">Xóa môn học</h2>
                <p class="text-sm text-on-surface-variant mb-4" style="font-family:'Inter',sans-serif">
                    Môn học sẽ bị ẩn khỏi luồng học tập. Giảng viên và sinh viên liên quan sẽ nhận thông báo.
                </p>
                <form method="post" action="@Url.Page("/Subject/Delete")" data-subject-delete-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="soft-delete-subject-id" />
                    <input type="hidden" name="statusFilter" value="@Model.ViewModel.StatusFilter" />
                    <label for="soft-delete-reason" class="text-sm font-semibold text-on-surface mb-2 block" style="font-family:'Inter',sans-serif">Lý do</label>
                    <textarea id="soft-delete-reason" name="reason" rows="4" maxlength="500"
                              class="w-full rounded-xl border border-outline-variant/60 px-3 py-2 text-sm"
                              style="font-family:'Inter',sans-serif"
                              placeholder="Nhập lý do xóa để lưu audit nội bộ."></textarea>
                    <div class="mt-5 flex justify-end gap-3">
                        <button type="button" class="px-4 py-2 rounded-xl border border-outline-variant/60 text-on-surface-variant font-semibold"
                                style="font-family:'Inter',sans-serif"
                                data-soft-delete-close>
                            Hủy
                        </button>
                        <button type="submit" class="px-4 py-2 rounded-xl text-white font-semibold"
                                style="background:#ba1a1a;font-family:'Inter',sans-serif">
                            Xóa
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        (() => {
            const region = document.getElementById('subject-list-region');
            if (!region || !window.signalR) {
                return;
            }

            const baseRefreshUrl = region.dataset.subjectListBaseUrl;
            let currentStatusFilter = region.dataset.statusFilter || 'active';
            let refreshUrl = region.dataset.subjectListUrl;
            let refreshTimer;

            function buildListUrl(statusFilter) {
                const url = new URL(baseRefreshUrl, window.location.origin);
                url.searchParams.set('statusFilter', statusFilter);
                return url.toString();
            }

            function showInlineMessage(succeeded, message) {
                const holder = document.getElementById('subject-inline-message');
                if (!holder) {
                    return;
                }

                holder.innerHTML = `
                    <div class="flex items-center gap-3 px-5 py-3 rounded-xl border text-sm"
                         style="${succeeded ? 'background:#e2dfff;border-color:#c3c0ff;color:#3525cd' : 'background:#ffdad6;border-color:#ffb4ab;color:#ba1a1a'};font-family:Inter,sans-serif">
                        <span class="material-symbols-outlined text-[18px]">${succeeded ? 'check_circle' : 'error'}</span>
                        <span>${message}</span>
                    </div>`;
            }

            function updateFilterButtons() {
                document.querySelectorAll('[data-subject-filter]').forEach(link => {
                    const isActive = link.dataset.subjectFilter === currentStatusFilter;
                    link.classList.toggle('text-white', isActive);
                    link.classList.toggle('text-on-surface-variant', !isActive);
                    link.style.background = isActive ? '#4f46e5' : '';
                    link.style.textDecoration = 'none';
                });
            }

            function showRealtimeError() {
                if (document.querySelector('[data-subject-realtime-error]')) {
                    return;
                }

                const banner = document.createElement('div');
                banner.dataset.subjectRealtimeError = 'true';
                banner.className = 'flex items-center gap-3 px-5 py-3 rounded-xl border text-sm';
                banner.style.cssText = 'background:#ffdad6;border-color:#ffb4ab;color:#ba1a1a;font-family:Inter,sans-serif';
                banner.innerHTML = '<span class="material-symbols-outlined text-[18px]">sync_problem</span><span>Không thể cập nhật realtime, vui lòng tải lại trang.</span>';
                region.parentElement?.insertBefore(banner, region);
            }

            async function refreshSubjects() {
                try {
                    const response = await fetch(refreshUrl, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (!response.ok) {
                        throw new Error('Partial refresh failed.');
                    }

                    region.innerHTML = await response.text();
                    region.dataset.subjectListUrl = refreshUrl;
                    region.dataset.statusFilter = currentStatusFilter;
                } catch {
                    showRealtimeError();
                }
            }

            function scheduleRefresh() {
                window.clearTimeout(refreshTimer);
                refreshTimer = window.setTimeout(refreshSubjects, 150);
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/subject-management')
                .withAutomaticReconnect()
                .build();

            [
                'SubjectCreated',
                'SubjectUpdated',
                'SubjectDeleted',
                'SubjectRestored',
                'SubjectMemberAdded',
                'SubjectMemberRemoved',
                'SubjectMembersImported'
            ].forEach(eventName => connection.on(eventName, scheduleRefresh));

            async function joinIndexGroup() {
                await connection.invoke('JoinSubjectIndex');
            }

            connection.onreconnected(async () => {
                try {
                    await joinIndexGroup();
                    await refreshSubjects();
                } catch {
                    showRealtimeError();
                }
            });

            connection.start()
                .then(joinIndexGroup)
                .catch(showRealtimeError);

            document.querySelectorAll('[data-subject-filter]').forEach(link => {
                link.addEventListener('click', async (event) => {
                    event.preventDefault();
                    currentStatusFilter = link.dataset.subjectFilter || 'active';
                    refreshUrl = buildListUrl(currentStatusFilter);
                    const pageUrl = new URL(window.location.href);
                    pageUrl.searchParams.set('statusFilter', currentStatusFilter);
                    window.history.pushState({}, '', pageUrl);
                    updateFilterButtons();
                    await refreshSubjects();
                });
            });

            const modal = document.getElementById('soft-delete-modal');
            const subjectInput = document.getElementById('soft-delete-subject-id');
            const reasonInput = document.getElementById('soft-delete-reason');
            window.openSubjectDeleteModal = (id) => {
                if (!modal || !subjectInput || !reasonInput) {
                    return;
                }

                subjectInput.value = id;
                reasonInput.value = '';
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                reasonInput.focus();
            };

            function closeDeleteModal() {
                modal?.classList.add('hidden');
                modal?.classList.remove('flex');
            }

            modal?.addEventListener('click', closeDeleteModal);
            document.querySelectorAll('[data-soft-delete-close]').forEach(button => {
                button.addEventListener('click', closeDeleteModal);
            });

            async function postSubjectForm(form) {
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new FormData(form)
                });
                if (!response.ok) {
                    throw new Error('Submit failed.');
                }

                const result = await response.json();
                showInlineMessage(Boolean(result.succeeded), result.message || '');
                closeDeleteModal();
                await refreshSubjects();
            }

            document.querySelector('[data-subject-delete-form]')?.addEventListener('submit', async (event) => {
                event.preventDefault();
                try {
                    await postSubjectForm(event.currentTarget);
                } catch {
                    showRealtimeError();
                }
            });

            region.addEventListener('submit', async (event) => {
                const form = event.target.closest('form[action*="/Subject/Restore"]');
                if (!form) {
                    return;
                }

                event.preventDefault();
                try {
                    await postSubjectForm(form);
                } catch {
                    showRealtimeError();
                }
            });
        })();
    </script>
}


