@if (User.IsInRole("Admin"))
{
    <div class="ragas-job-widget d-none" data-ragas-job-widget aria-live="polite">
        <div class="ragas-job-widget__header">
            <div>
                <div class="ragas-job-widget__eyebrow" data-ragas-job-status>Đánh giá RAG</div>
                <div class="ragas-job-widget__title" data-ragas-job-subject>Đang chuẩn bị...</div>
            </div>
            <strong class="ragas-job-widget__percent" data-ragas-job-percent>0%</strong>
        </div>
        <div class="ragas-job-widget__message" data-ragas-job-message>Đang tải trạng thái benchmark...</div>
        <div class="ragas-job-widget__context" data-ragas-job-context></div>
        <div class="ragas-job-widget__bar" role="progressbar" aria-label="Tiến trình đánh giá RAG" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
            <span data-ragas-job-bar></span>
        </div>
        <div class="ragas-job-widget__meta">
            <span data-ragas-job-steps>0/0 bước</span>
            <span data-ragas-job-elapsed>00:00</span>
            <span data-ragas-job-eta>ETA: Đang tính...</span>
        </div>
        <div class="ragas-job-widget__actions">
            <a class="btn btn-sm btn-outline-primary rounded-pill" data-ragas-job-open-questions href="#">Mở bộ câu hỏi</a>
            <a class="btn btn-sm btn-primary rounded-pill d-none" data-ragas-job-open-history href="#">Lịch sử</a>
        </div>
    </div>

    <style>
        .ragas-job-widget {
            position: fixed;
            right: 1.25rem;
            bottom: 1.25rem;
            z-index: 1080;
            width: min(420px, calc(100vw - 2rem));
            background: #fff;
            border: 1px solid #d9e2ef;
            border-radius: 8px;
            box-shadow: 0 18px 46px rgba(15, 23, 42, 0.18);
            padding: 1rem;
        }

        .ragas-job-widget.is-running { border-color: #86b7fe; }
        .ragas-job-widget.is-completed { border-color: #75b798; }
        .ragas-job-widget.is-failed { border-color: #f1aeb5; }

        .ragas-job-widget__header,
        .ragas-job-widget__meta,
        .ragas-job-widget__actions {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
        }

        .ragas-job-widget__eyebrow,
        .ragas-job-widget__message,
        .ragas-job-widget__context,
        .ragas-job-widget__meta {
            font-size: 0.8125rem;
        }

        .ragas-job-widget__eyebrow {
            color: #5c6573;
            font-weight: 700;
            text-transform: uppercase;
        }

        .ragas-job-widget__title {
            color: #111827;
            font-weight: 700;
            line-height: 1.3;
            margin-top: 0.1rem;
        }

        .ragas-job-widget__percent {
            color: #0d6efd;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .ragas-job-widget__message {
            color: #1f2937;
            margin-top: 0.7rem;
            font-weight: 600;
        }

        .ragas-job-widget__context {
            color: #5c6573;
            margin-top: 0.25rem;
            min-height: 1.25rem;
        }

        .ragas-job-widget__bar {
            height: 0.55rem;
            background: #edf2f7;
            border-radius: 999px;
            overflow: hidden;
            margin: 0.85rem 0 0.65rem;
        }

        .ragas-job-widget__bar span {
            display: block;
            width: 0%;
            height: 100%;
            background: #0d6efd;
            transition: width 220ms ease;
        }

        .ragas-job-widget.is-completed .ragas-job-widget__bar span { background: #198754; }
        .ragas-job-widget.is-failed .ragas-job-widget__bar span { background: #dc3545; }
        .ragas-job-widget__meta { color: #4b5563; flex-wrap: wrap; }
        .ragas-job-widget__actions { justify-content: flex-end; margin-top: 0.85rem; }
    </style>
}
