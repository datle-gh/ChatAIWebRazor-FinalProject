@page "/AdminUsers/ResetPassword"
@model Presentation.Pages.AdminUsers.ResetPasswordModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h1 class="h3 mb-3">Đặt lại mật khẩu</h1>
        <div class="text-muted mb-3">@Model.ViewModel.UserDisplayName</div>

        <form asp-page="/AdminUsers/ResetPassword" method="post" class="border rounded-2 p-4 bg-light">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input asp-for="ViewModel.UserId" type="hidden" />
            <input asp-for="ViewModel.UserDisplayName" type="hidden" />

            <div class="mb-3">
                <label asp-for="ViewModel.NewPassword" class="form-label"></label>
                <input asp-for="ViewModel.NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ViewModel.NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ViewModel.ConfirmNewPassword" class="form-label"></label>
                <input asp-for="ViewModel.ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ViewModel.ConfirmNewPassword" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Đặt lại mật khẩu</button>
                <a class="btn btn-outline-secondary" asp-page="/AdminUsers/Index">Huỷ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


