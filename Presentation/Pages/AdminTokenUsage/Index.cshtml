@page "/AdminTokenUsage/Index"
@using System.Globalization
@model Presentation.Pages.AdminTokenUsage.IndexModel

@{
    ViewData["Title"] = "Thống kê token";
    var embeddingPeriods = new[]
    {
        new { Key = "today", Label = "Hôm nay", Items = Model.ViewModel.EmbeddingUsage.Today },
        new { Key = "week", Label = "Tuần này", Items = Model.ViewModel.EmbeddingUsage.ThisWeek },
        new { Key = "month", Label = "Tháng này", Items = Model.ViewModel.EmbeddingUsage.ThisMonth }
    };

    var embeddingChartColors = new[] { "#2563eb", "#dc2626", "#84cc16", "#f97316", "#9333ea", "#0891b2", "#be123c", "#ca8a04" };
    var embeddingModelColors = embeddingPeriods
        .SelectMany(period => period.Items)
        .Select(item => item.EmbeddingModel)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(model => model, StringComparer.OrdinalIgnoreCase)
        .Select((model, index) => new { model, Color = embeddingChartColors[index % embeddingChartColors.Length] })
        .ToDictionary(item => item.model, item => item.Color, StringComparer.OrdinalIgnoreCase);
    var dailyChart = Model.ViewModel.DailyEmbeddingUsage;
    var chartWidth = 980;
    var chartHeight = 340;
    var paddingLeft = 64;
    var paddingRight = 28;
    var paddingTop = 24;
    var paddingBottom = 56;
    var plotWidth = chartWidth - paddingLeft - paddingRight;
    var plotHeight = chartHeight - paddingTop - paddingBottom;
    var maxDailyTokens = Math.Max(1, dailyChart.MaxTokenCount);
    var xStep = dailyChart.Labels.Count > 1 ? plotWidth / (double)(dailyChart.Labels.Count - 1) : plotWidth;
    var labelEvery = dailyChart.Labels.Count > 20 ? 3 : dailyChart.Labels.Count > 12 ? 2 : 1;
    var yTicks = Enumerable.Range(0, 5)
        .Select(index => (int)Math.Round(maxDailyTokens * index / 4d))
        .Distinct()
        .ToList();
}

<style>

    .embedding-token-chart {
        overflow-x: auto;
    }

    .embedding-token-panel {
        min-width: 620px;
    }

    .embedding-token-row {
        display: grid;
        grid-template-columns: minmax(150px, 220px) minmax(320px, 1fr) minmax(88px, auto);
        align-items: center;
        gap: 1.25rem;
        min-height: 56px;
    }

    .embedding-token-label {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        min-width: 0;
    }

    .embedding-token-plot {
        position: relative;
        min-height: 32px;
        padding: 7px 0;
    }

    .embedding-token-grid {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: space-between;
        pointer-events: none;
    }

    .embedding-token-grid span {
        width: 1px;
        height: 100%;
        background: #dbe1ea;
    }

    .embedding-token-bar {
        position: relative;
        z-index: 1;
        height: 18px;
        min-width: 2px;
        border-radius: 1px;
        transition: width 180ms ease;
    }

    .embedding-token-value {
        font-weight: 700;
        color: #0f172a;
        text-align: right;
        white-space: nowrap;
    }

    .embedding-token-axis {
        display: grid;
        grid-template-columns: minmax(150px, 220px) minmax(320px, 1fr) minmax(88px, auto);
        gap: 1.25rem;
        margin-bottom: 0.55rem;
    }

    .embedding-token-axis-values {
        position: relative;
        height: 20px;
        color: #64748b;
        font-size: 11px;
    }

    .embedding-token-axis-values span {
        position: absolute;
        transform: translateX(-50%);
        white-space: nowrap;
    }

    .embedding-token-axis-values span:first-child {
        transform: none;
    }

    .embedding-token-axis-values span:last-child {
        transform: translateX(-100%);
    }
    .token-line-chart-wrap {
        overflow-x: auto;
    }

    .token-line-chart {
        min-width: 760px;
        width: 100%;
        height: auto;
    }

    .chart-grid-line {
        stroke: #e5e7eb;
        stroke-width: 1;
    }

    .chart-axis-line {
        stroke: #94a3b8;
        stroke-width: 1.2;
    }

    .chart-axis-label {
        fill: #64748b;
        font-size: 12px;
    }

    .chart-line {
        fill: none;
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        transition: stroke-width 160ms ease;
    }

    .chart-point {
        stroke: #ffffff;
        stroke-width: 1.6;
    }

    .chart-series {
        opacity: 1;
        transition: opacity 180ms ease;
    }

    .chart-series.is-dimmed {
        opacity: 0.12;
    }

    .chart-series.is-active .chart-line {
        stroke-width: 3.5;
    }

    .chart-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1rem;
    }

    .chart-legend-item {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.2rem 0.25rem;
        border: 0;
        border-radius: 0.25rem;
        background: transparent;
        font-weight: 600;
        color: #334155;
        cursor: pointer;
        transition: opacity 180ms ease, background-color 180ms ease;
    }

    .chart-legend-item:hover,
    .chart-legend-item:focus-visible,
    .chart-legend-item.is-active {
        background: #f1f5f9;
        outline: none;
    }

    .chart-legend.has-highlight .chart-legend-item:not(.is-active) {
        opacity: 0.35;
    }

    .chart-legend-swatch {
        width: 0.85rem;
        height: 0.85rem;
        border-radius: 999px;
        display: inline-block;
    }

    @@media (max-width: 768px) {
        .embedding-token-chart {
            margin-inline: -0.5rem;
            padding-inline: 0.5rem;
        }
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1">Thống kê token</h1>
            <p class="text-muted mb-0">Tổng hợp lượng token người dùng đã sử dụng trong Gia sư AI.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-primary" asp-page="/AdminTokenUsage/Users">
                <span class="material-symbols-outlined align-middle me-1" style="font-size:1.1rem">group</span>
                Theo user
            </a>
            <a class="btn btn-outline-secondary" asp-page="/AdminDashboard/Index">
                <span class="material-symbols-outlined align-middle me-1" style="font-size:1.1rem">insert_chart</span>
                Dashboard
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="border rounded-3 bg-white p-4 h-100">
                <div class="text-muted small text-uppercase fw-semibold">Tổng token</div>
                <div class="h2 fw-bold mb-0">@Model.ViewModel.Summary.TotalTokens.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded-3 bg-white p-4 h-100">
                <div class="text-muted small text-uppercase fw-semibold">Input token</div>
                <div class="h2 fw-bold mb-0">@Model.ViewModel.Summary.PromptTokens.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded-3 bg-white p-4 h-100">
                <div class="text-muted small text-uppercase fw-semibold">Output token</div>
                <div class="h2 fw-bold mb-0">@Model.ViewModel.Summary.CompletionTokens.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="border rounded-3 bg-white p-4 h-100">
                <div class="text-muted small text-uppercase fw-semibold">Câu trả lời</div>
                <div class="h2 fw-bold mb-0">@Model.ViewModel.Summary.AnswerCount.ToString("N0")</div>
            </div>
        </div>
    </div>

    <div class="border rounded-3 bg-white p-4 mb-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
            <div>
                <h2 class="h5 mb-1">Token embedding theo model</h2>
                <p class="text-muted mb-0">Tổng token embedding toàn hệ thống theo từng khoảng thời gian.</p>
            </div>
            <div class="btn-group" role="group" aria-label="Chọn khoảng thời gian thống kê embedding token">
                @foreach (var period in embeddingPeriods)
                {
                    <button type="button"
                            class="btn @(period.Key == "today" ? "btn-primary" : "btn-outline-primary")"
                            data-embedding-period="@period.Key">
                        @period.Label
                    </button>
                }
            </div>
        </div>

        <div class="embedding-token-chart">
            @foreach (var period in embeddingPeriods)
            {
                var maxTokens = Math.Max(1, period.Items.Count == 0 ? 1 : period.Items.Max(item => item.TokenCount));
                var axisTicks = Enumerable.Range(0, 5)
                    .Select(index => new { Position = index * 25, Value = (int)Math.Round(maxTokens * index / 4d) })
                    .ToList();
                <div class="embedding-token-panel @(period.Key == "today" ? string.Empty : "d-none")" data-embedding-period-panel="@period.Key">
                    @if (period.Items.Count == 0)
                    {
                        <div class="text-center text-muted py-5 border rounded-3 bg-light">
                            <span class="material-symbols-outlined d-block mb-2" style="font-size:2rem">bar_chart</span>
                            Chưa có dữ liệu embedding token trong khoảng thời gian này.
                        </div>
                    }
                    else
                    {
                        <div class="embedding-token-axis" aria-hidden="true">
                            <div></div>
                            <div class="embedding-token-axis-values">
                                @foreach (var tick in axisTicks)
                                {
                                    <span style="left:@tick.Position%">@tick.Value.ToString("N0")</span>
                                }
                            </div>
                            <div></div>
                        </div>

                        foreach (var item in period.Items)
                        {
                            var barWidth = Math.Max(0, (int)Math.Round(item.TokenCount * 100d / maxTokens));
                            var barColor = embeddingModelColors.TryGetValue(item.EmbeddingModel, out var color) ? color : "#2563eb";
                            <div class="embedding-token-row">
                                <div class="embedding-token-label">
                                    <span class="fw-semibold">@item.EmbeddingModel</span>
                                    <span class="text-muted small">@item.EmbeddingCount.ToString("N0") lượt embedding</span>
                                </div>
                                <div class="embedding-token-plot" aria-label="@item.EmbeddingModel: @item.TokenCount.ToString("N0") token">
                                    <div class="embedding-token-grid" aria-hidden="true">
                                        @foreach (var tick in axisTicks)
                                        {
                                            <span></span>
                                        }
                                    </div>
                                    <div class="embedding-token-bar" style="width:@barWidth%; background-color:@barColor" title="@item.EmbeddingModel: @item.TokenCount.ToString("N0") token"></div>
                                </div>
                                <div class="embedding-token-value">@item.TokenCount.ToString("N0")</div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>

    <div class="border rounded-3 bg-white p-4 mb-4">
        <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h2 class="h5 mb-1">Token embedding theo ngày trong tháng</h2>
                <p class="text-muted mb-0">Mỗi đường thể hiện token embedding của một model trong tháng hiện tại.</p>
            </div>
            @if (dailyChart.Series.Count > 0 && dailyChart.MaxTokenCount > 0)
            {
                <div class="chart-legend" data-line-chart-legend>
                    @for (var seriesIndex = 0; seriesIndex < dailyChart.Series.Count; seriesIndex++)
                    {
                        var series = dailyChart.Series[seriesIndex];
                        <button type="button"
                                class="chart-legend-item"
                                data-line-series-legend="@seriesIndex"
                                aria-label="Làm nổi bật model @series.EmbeddingModel">
                            <span class="chart-legend-swatch" style="background:@series.Color"></span>
                            @series.EmbeddingModel
                        </button>
                    }
                </div>
            }
        </div>

        @if (dailyChart.Series.Count == 0 || dailyChart.MaxTokenCount <= 0)
        {
            <div class="text-center text-muted py-5 border rounded-3 bg-light">
                <span class="material-symbols-outlined d-block mb-2" style="font-size:2rem">show_chart</span>
                Chưa có dữ liệu.
            </div>
        }
        else
        {
            <div class="token-line-chart-wrap">
                <svg class="token-line-chart" viewBox="0 0 @chartWidth @chartHeight" role="img" aria-label="Biểu đồ token embedding theo ngày trong tháng">
                    @foreach (var tick in yTicks)
                    {
                        var y = paddingTop + plotHeight - (tick * plotHeight / (double)maxDailyTokens);
                        <line class="chart-grid-line" x1="@paddingLeft" y1="@y.ToString("0.##", CultureInfo.InvariantCulture)" x2="@(chartWidth - paddingRight)" y2="@y.ToString("0.##", CultureInfo.InvariantCulture)" />
                        @Html.Raw($"<text class=\"chart-axis-label\" x=\"{paddingLeft - 10}\" y=\"{(y + 4).ToString("0.##", CultureInfo.InvariantCulture)}\" text-anchor=\"end\">{tick.ToString("N0")}</text>")
                    }

                    <line class="chart-axis-line" x1="@paddingLeft" y1="@paddingTop" x2="@paddingLeft" y2="@(paddingTop + plotHeight)" />
                    <line class="chart-axis-line" x1="@paddingLeft" y1="@(paddingTop + plotHeight)" x2="@(chartWidth - paddingRight)" y2="@(paddingTop + plotHeight)" />

                    @for (var index = 0; index < dailyChart.Labels.Count; index++)
                    {
                        if (index % labelEvery == 0 || index == dailyChart.Labels.Count - 1)
                        {
                            var x = paddingLeft + index * xStep;
                            @Html.Raw($"<text class=\"chart-axis-label\" x=\"{x.ToString("0.##", CultureInfo.InvariantCulture)}\" y=\"{chartHeight - 24}\" text-anchor=\"middle\">{dailyChart.Labels[index]}</text>")
                        }
                    }

                    @for (var seriesIndex = 0; seriesIndex < dailyChart.Series.Count; seriesIndex++)
                    {
                        var series = dailyChart.Series[seriesIndex];
                        var points = new List<string>();
                        for (var index = 0; index < series.Values.Count; index++)
                        {
                            var x = paddingLeft + index * xStep;
                            var y = paddingTop + plotHeight - (series.Values[index] * plotHeight / (double)maxDailyTokens);
                            points.Add($"{x.ToString("0.##", CultureInfo.InvariantCulture)},{y.ToString("0.##", CultureInfo.InvariantCulture)}");
                        }

                        var pointText = string.Join(" ", points);
                        <g class="chart-series" data-line-chart-series="@seriesIndex">
                            <polyline class="chart-line" points="@pointText" stroke="@series.Color" />

                            @for (var index = 0; index < series.Values.Count; index++)
                            {
                                if (series.Values[index] <= 0)
                                {
                                    continue;
                                }

                                var x = paddingLeft + index * xStep;
                                var y = paddingTop + plotHeight - (series.Values[index] * plotHeight / (double)maxDailyTokens);
                                <circle class="chart-point" cx="@x.ToString("0.##", CultureInfo.InvariantCulture)" cy="@y.ToString("0.##", CultureInfo.InvariantCulture)" r="3.5" fill="@series.Color">
                                    <title>@series.EmbeddingModel - @dailyChart.Labels[index]: @series.Values[index].ToString("N0") token</title>
                                </circle>
                            }
                        </g>
                    }
                </svg>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const buttons = Array.from(document.querySelectorAll('[data-embedding-period]'));
            const panels = Array.from(document.querySelectorAll('[data-embedding-period-panel]'));
            const lineChartLegend = document.querySelector('[data-line-chart-legend]');
            const lineSeriesLegends = Array.from(document.querySelectorAll('[data-line-series-legend]'));
            const lineChartSeries = Array.from(document.querySelectorAll('[data-line-chart-series]'));

            function highlightLineSeries(seriesIndex) {
                if (!lineChartLegend) {
                    return;
                }

                lineChartLegend.classList.add('has-highlight');
                lineSeriesLegends.forEach(function (item) {
                    item.classList.toggle('is-active', item.dataset.lineSeriesLegend === seriesIndex);
                });
                lineChartSeries.forEach(function (series) {
                    const active = series.dataset.lineChartSeries === seriesIndex;
                    series.classList.toggle('is-active', active);
                    series.classList.toggle('is-dimmed', !active);
                });
            }

            function clearLineSeriesHighlight() {
                if (lineChartLegend) {
                    lineChartLegend.classList.remove('has-highlight');
                }
                lineSeriesLegends.forEach(function (item) {
                    item.classList.remove('is-active');
                });
                lineChartSeries.forEach(function (series) {
                    series.classList.remove('is-active', 'is-dimmed');
                });
            }

            lineSeriesLegends.forEach(function (item) {
                item.addEventListener('pointerenter', function () {
                    highlightLineSeries(item.dataset.lineSeriesLegend);
                });
                item.addEventListener('pointerleave', clearLineSeriesHighlight);
                item.addEventListener('focus', function () {
                    highlightLineSeries(item.dataset.lineSeriesLegend);
                });
                item.addEventListener('blur', clearLineSeriesHighlight);
            });

            buttons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const period = button.dataset.embeddingPeriod;

                    buttons.forEach(function (item) {
                        const active = item === button;
                        item.classList.toggle('btn-primary', active);
                        item.classList.toggle('btn-outline-primary', !active);
                    });

                    panels.forEach(function (panel) {
                        panel.classList.toggle('d-none', panel.dataset.embeddingPeriodPanel !== period);
                    });
                });
            });
        });
    </script>
}
