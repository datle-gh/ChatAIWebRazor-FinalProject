@page "/Account/Profile"
@model Presentation.Pages.Account.ProfileModel

@{
    ViewData["Title"] = "Tài khoản cá nhân";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h1 class="h3 mb-3">Tài khoản cá nhân</h1>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success" role="alert">@successMessage</div>
        }

        <form asp-page="/Account/Profile" method="post" class="border rounded-2 p-4 bg-light">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input asp-for="ViewModel.Id" type="hidden" />
            <input asp-for="ViewModel.Role" type="hidden" />

            <div class="mb-3">
                <label asp-for="ViewModel.FullName" class="form-label"></label>
                <input asp-for="ViewModel.FullName" class="form-control" />
                <span asp-validation-for="ViewModel.FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ViewModel.Email" class="form-label"></label>
                <input asp-for="ViewModel.Email" class="form-control" autocomplete="username" />
                <span asp-validation-for="ViewModel.Email" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Vai trò</label>
                <input value="@Model.ViewModel.Role" class="form-control" disabled />
            </div>

            <hr />
            <h2 class="h5 mb-3">Đổi mật khẩu</h2>
            <div class="text-muted mb-3">Bỏ trống phần này nếu bạn không muốn đổi mật khẩu.</div>

            <div class="mb-3">
                <label asp-for="ViewModel.CurrentPassword" class="form-label"></label>
                <input asp-for="ViewModel.CurrentPassword" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="ViewModel.CurrentPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ViewModel.NewPassword" class="form-label"></label>
                <input asp-for="ViewModel.NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ViewModel.NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ViewModel.ConfirmNewPassword" class="form-label"></label>
                <input asp-for="ViewModel.ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ViewModel.ConfirmNewPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


