@page "/SystemSettings/Index"
@model Presentation.Pages.SystemSettings.IndexModel

@{
    ViewData["Title"] = "Cấu hình Hệ thống";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-gray-800 fw-bold">Cấu hình LLM & RAG</h1>
            <p class="text-muted mb-0">Thay đổi API Keys, Models và tham số thuật toán tìm kiếm Vector</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ViewModel.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
            <span class="material-symbols-outlined fs-5 align-text-bottom me-1">check_circle</span>
            @Model.ViewModel.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    
    @if (!string.IsNullOrEmpty(Model.ViewModel.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
            <span class="material-symbols-outlined fs-5 align-text-bottom me-1">error</span>
            @Model.ViewModel.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
<div id="testConnectionAlert" class="alert d-none alert-dismissible fade show shadow-sm border-0" role="alert">
        <span class="material-symbols-outlined fs-5 align-text-bottom me-1 alert-icon"></span>
        <span class="alert-message"></span>
        <button type="button" class="btn-close" onclick="$(this).parent().addClass('d-none')"></button>
    </div>

    <form asp-page="/SystemSettings/Save" method="post" id="settingsForm">
        <div class="row g-4">
            <!-- Left Column: LLM & Embedding -->
            <div class="col-lg-6">
                <!-- LLM Provider Config -->
                <div class="card shadow-sm border-0 mb-4 rounded-4">
                    <div class="card-header bg-white py-3 border-bottom-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary">smart_toy</span>
                        <h6 class="m-0 font-weight-bold text-primary">Cấu hình mô hình ngôn ngữ lớn (LLM Generator)</h6>
                    </div>
                    <div class="card-body bg-light rounded-bottom-4 pt-1">
                        <div class="mb-3 bg-white p-3 rounded shadow-sm">
                            <label class="form-label fw-semibold">LLM Provider</label>
                            <select asp-for="ViewModel.LlmProvider" class="form-select border-0 bg-light" id="LlmProvider">
                                <option value="Fake">Fake (Test/Mock)</option>
                                <option value="Gemini">Google Gemini</option>
                                <option value="OpenAI">OpenAI ChatGPT</option>
                            </select>
                        </div>

                        <!-- Gemini Config -->
                        <div class="provider-config" id="config-Gemini">
                            <div class="mb-3">
                                <label asp-for="ViewModel.GeminiApiKey" class="form-label fw-semibold text-muted small text-uppercase">Google Gemini API Key</label>
                                <input asp-for="ViewModel.GeminiApiKey" type="password" class="form-control" id="GeminiApiKey" placeholder="AIzaSy...">
                            </div>
                            <div class="mb-3">
                                <label asp-for="ViewModel.GeminiModel" class="form-label fw-semibold text-muted small text-uppercase">Gemini Model</label>
                                <select asp-for="ViewModel.GeminiModel" class="form-select" id="GeminiModel">
                                    <option value="gemini-2.0-flash">gemini-2.0-flash (Khuyên dùng)</option>
                                    <option value="gemini-1.5-pro">gemini-1.5-pro</option>
                                </select>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary btn-test-connection" data-provider="Gemini">Kiểm tra kết nối Gemini</button>
                        </div>

                        <!-- OpenAI Config -->
                        <div class="provider-config" id="config-OpenAI" style="display: none;">
                            <div class="mb-3">
                                <label asp-for="ViewModel.OpenAiApiKey" class="form-label fw-semibold text-muted small text-uppercase">OpenAI API Key</label>
                                <input asp-for="ViewModel.OpenAiApiKey" type="password" class="form-control" id="OpenAiApiKey" placeholder="sk-...">
                            </div>
                            <div class="mb-3">
                                <label asp-for="ViewModel.OpenAiModel" class="form-label fw-semibold text-muted small text-uppercase">OpenAI Model</label>
                                <select asp-for="ViewModel.OpenAiModel" class="form-select" id="OpenAiModel">
                                    <option value="gpt-4o-mini">gpt-4o-mini (Khuyên dùng)</option>
                                    <option value="gpt-4o">gpt-4o</option>
                                </select>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary btn-test-connection" data-provider="OpenAI">Kiểm tra kết nối OpenAI</button>
                        </div>
                    </div>
                </div>

                <!-- Embedding Config -->
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white py-3 border-bottom-0 d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-success">account_tree</span>
                        <h6 class="m-0 font-weight-bold text-success">Cấu hình mô hình Vector (Embedding)</h6>
                    </div>
                    <div class="card-body bg-light rounded-bottom-4 pt-1">
                        <input asp-for="ViewModel.EmbeddingProvider" type="hidden" id="EmbeddingProvider" />

                        <div class="mb-3 bg-white p-3 rounded shadow-sm">
                            <label asp-for="ViewModel.EmbeddingModel" class="form-label fw-semibold">Model Embedding</label>
                            <select asp-for="ViewModel.EmbeddingModel" class="form-select border-0 bg-light" id="EmbeddingModel">
                                @foreach (var embeddingModel in Model.EmbeddingModels)
                                {
                                    <option value="@embeddingModel.Key" data-provider="@embeddingModel.Provider" data-model="@embeddingModel.Model" data-dimension="@embeddingModel.Dimension">
                                        @embeddingModel.Label
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="ViewModel.EmbeddingModel" class="text-danger small"></span>
                            <small class="form-text text-muted">Chỉ hiển thị các model embedding thật đang bật trong dự án.</small>
                        </div>

                        <div class="d-flex flex-wrap gap-2 small text-body" id="EmbeddingModelMeta">
                            <span class="badge rounded-pill bg-white text-dark border border-secondary-subtle shadow-sm d-inline-flex align-items-center gap-1">
                                <span class="material-symbols-outlined text-success" style="font-size: 1rem;">hub</span>
                                <span id="EmbeddingProviderLabel">@Model.ViewModel.EmbeddingProvider</span>
                            </span>
                            <span class="badge rounded-pill bg-white text-dark border border-secondary-subtle shadow-sm d-inline-flex align-items-center gap-1">
                                <span class="material-symbols-outlined text-success" style="font-size: 1rem;">memory</span>
                                <span id="EmbeddingModelNameLabel"></span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: RAG Parameters & Prompts -->
            <div class="col-lg-6">
                <!-- RAG Config -->
                <div class="card shadow-sm border-0 mb-4 rounded-4">
                    <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-warning">tune</span>
                        <h6 class="m-0 font-weight-bold text-warning">Tham số thuật toán RAG (Retrieval)</h6>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-6">
                                <label asp-for="ViewModel.TopK" class="form-label fw-semibold">Top K (Số đoạn text)</label>
                                <input asp-for="ViewModel.TopK" type="number" class="form-control" min="1" max="20" />
                                <small class="form-text text-muted">Số lượng chunks đưa vào Prompt.</small>
                            </div>
                            <div class="col-6">
                                <label asp-for="ViewModel.SimilarityThreshold" class="form-label fw-semibold">Ngưỡng tương đồng</label>
                                <input asp-for="ViewModel.SimilarityThreshold" type="number" step="0.05" class="form-control" min="0" max="1" />
                                <small class="form-text text-muted">Cosine similarity tối thiểu.</small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ViewModel.MaxCitationSnippetLength" class="form-label fw-semibold">Độ dài trích dẫn tối đa (ký tự)</label>
                            <input asp-for="ViewModel.MaxCitationSnippetLength" type="number" class="form-control" min="50" max="1000" />
                        </div>
                    </div>
                </div>

                <!-- Chunking Config -->
                <div class="card shadow-sm border-0 mb-4 rounded-4">
                    <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-secondary">segment</span>
                        <h6 class="m-0 font-weight-bold text-secondary">Cấu hình chia chunk</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="ViewModel.ChunkSizeMode" class="form-label fw-semibold">Kiểu chia chunk</label>
                            <input asp-for="ViewModel.ChunkSizeMode" type="hidden" id="ChunkSizeMode" />
                            <div class="dropdown">
                                <button class="form-select text-start d-flex align-items-center gap-2" type="button" id="ChunkSizeModeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span id="ChunkSizeModeIcon" class="material-symbols-outlined text-secondary" style="font-size: 1.25rem;">auto_stories</span>
                                    <span id="ChunkSizeModeLabel">Theo trang/slide</span>
                                </button>
                                <ul class="dropdown-menu w-100 shadow-sm" aria-labelledby="ChunkSizeModeDropdown">
                                    <li>
                                        <button class="dropdown-item d-flex align-items-center gap-2 chunk-mode-option" type="button" data-value="Page" data-icon="auto_stories" data-label="Theo trang/slide">
                                            <span class="material-symbols-outlined text-secondary" style="font-size: 1.2rem;">auto_stories</span>
                                            <span>Theo trang/slide</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item d-flex align-items-center gap-2 chunk-mode-option" type="button" data-value="Word" data-icon="short_text" data-label="Theo số từ">
                                            <span class="material-symbols-outlined text-secondary" style="font-size: 1.2rem;">short_text</span>
                                            <span>Theo số từ</span>
                                        </button>
                                    </li>
                                    <li>
                                        <button class="dropdown-item d-flex align-items-center gap-2 chunk-mode-option" type="button" data-value="Character" data-icon="text_fields" data-label="Theo số ký tự">
                                            <span class="material-symbols-outlined text-secondary" style="font-size: 1.2rem;">text_fields</span>
                                            <span>Theo số ký tự</span>
                                        </button>
                                    </li>
                                </ul>
                            </div>
                            <span asp-validation-for="ViewModel.ChunkSizeMode" class="text-danger small"></span>
                            <small class="form-text text-muted">Cấu hình này áp dụng cho tài liệu được index sau khi lưu.</small>
                        </div>

                        <div class="chunk-size-config" id="chunk-size-Page">
                            <label asp-for="ViewModel.PageChunkSize" class="form-label fw-semibold">Số trang/slide mỗi chunk</label>
                            <input asp-for="ViewModel.PageChunkSize" type="number" class="form-control" min="1" max="20" />
                            <span asp-validation-for="ViewModel.PageChunkSize" class="text-danger small"></span>
                            <small class="form-text text-muted">Giá trị 1 giữ hành vi gần giống hiện tại.</small>
                        </div>

                        <div class="chunk-size-config" id="chunk-size-Word">
                            <label asp-for="ViewModel.WordChunkSize" class="form-label fw-semibold">Số từ mỗi chunk</label>
                            <input asp-for="ViewModel.WordChunkSize" type="number" class="form-control" min="50" max="3000" />
                            <span asp-validation-for="ViewModel.WordChunkSize" class="text-danger small"></span>
                        </div>

                        <div class="chunk-size-config" id="chunk-size-Character">
                            <label asp-for="ViewModel.CharacterChunkSize" class="form-label fw-semibold">Số ký tự mỗi chunk</label>
                            <input asp-for="ViewModel.CharacterChunkSize" type="number" class="form-control" min="200" max="20000" />
                            <span asp-validation-for="ViewModel.CharacterChunkSize" class="text-danger small"></span>
                        </div>

                        <div class="row mt-3" id="chunk-overlap-row">
                            <div class="col-6">
                                <label asp-for="ViewModel.ChunkOverlapSize" class="form-label fw-semibold">Overlap</label>
                                <input asp-for="ViewModel.ChunkOverlapSize" type="number" class="form-control" min="0" max="2000" />
                                <span asp-validation-for="ViewModel.ChunkOverlapSize" class="text-danger small"></span>
                                <small class="form-text text-muted">Dùng cho mode từ/ký tự.</small>
                            </div>
                            <div class="col-6">
                                <label asp-for="ViewModel.MinChunkCharacters" class="form-label fw-semibold">Độ dài tối thiểu</label>
                                <input asp-for="ViewModel.MinChunkCharacters" type="number" class="form-control" min="1" max="1000" />
                                <span asp-validation-for="ViewModel.MinChunkCharacters" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Prompts Config -->
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-info">chat</span>
                        <h6 class="m-0 font-weight-bold text-info">System Prompts</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <label asp-for="ViewModel.ChatSystemPrompt" class="form-label fw-semibold">System Prompt cho Chatbot</label>
                            <textarea asp-for="ViewModel.ChatSystemPrompt" class="form-control font-monospace" rows="4" style="font-size: 0.85rem;" placeholder="Bạn là AI trợ giảng. Hãy dùng ngữ cảnh sau..."></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="ViewModel.EvaluationSystemPrompt" class="form-label fw-semibold">System Prompt cho LLM-as-a-judge (RAGAS)</label>
                            <textarea asp-for="ViewModel.EvaluationSystemPrompt" class="form-control font-monospace" rows="4" style="font-size: 0.85rem;" placeholder="Bạn là hệ thống chấm điểm RAG..."></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 bg-white p-3 rounded shadow-sm d-flex justify-content-end gap-3 sticky-bottom border-top">
            <button type="button" class="btn btn-light rounded-pill px-4" onclick="location.reload()">Hủy thay đổi</button>
            <button type="submit" class="btn btn-primary rounded-pill px-5 d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">save</span> Lưu cấu hình
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Toggle provider configs
            function updateProviderVisibility() {
                $('.provider-config').hide();
                const provider = $('#LlmProvider').val();
                if (provider !== 'Fake') {
                    $('#config-' + provider).fadeIn();
                }
            }

            $('#LlmProvider').change(updateProviderVisibility);
            updateProviderVisibility();
            function updateEmbeddingModelMeta() {
                const selected = $('#EmbeddingModel option:selected');
                const provider = selected.data('provider') || '';
                const model = selected.data('model') || '';

                $('#EmbeddingProvider').val(provider);
                $('#EmbeddingProviderLabel').text(provider || 'N/A');
                $('#EmbeddingModelNameLabel').text(model || selected.val() || 'N/A');
            }

            $('#EmbeddingModel').change(updateEmbeddingModelMeta);
            updateEmbeddingModelMeta();

            function setChunkMode(value) {
                const selectedOption = $('.chunk-mode-option[data-value="' + value + '"]');
                const fallbackOption = $('.chunk-mode-option[data-value="Page"]');
                const option = selectedOption.length ? selectedOption : fallbackOption;
                const mode = option.data('value');

                $('#ChunkSizeMode').val(mode);
                $('#ChunkSizeModeIcon').text(option.data('icon'));
                $('#ChunkSizeModeLabel').text(option.data('label'));
                $('.chunk-mode-option').removeClass('active');
                option.addClass('active');
                $('.chunk-size-config').hide();
                $('#chunk-size-' + mode).fadeIn(150);
                $('#chunk-overlap-row').toggle(mode !== 'Page');
            }

            $('.chunk-mode-option').click(function () {
                setChunkMode($(this).data('value'));
            });
            setChunkMode($('#ChunkSizeMode').val());

            // Test Connection Logic
            $('.btn-test-connection').click(function () {
                const btn = $(this);
                const provider = btn.data('provider');
                const apiKey = $('#' + provider + 'ApiKey').val();
                const model = $('#' + provider + 'Model').val();
                
                const alertBox = $('#testConnectionAlert');
                const alertIcon = alertBox.find('.alert-icon');
                const alertMsg = alertBox.find('.alert-message');

                if (!apiKey) {
                    alertBox.removeClass('d-none alert-success alert-info').addClass('alert-danger');
                    alertIcon.text('error');
                    alertMsg.text('Vui lòng nhập API Key trước khi kiểm tra.');
                    return;
                }

                btn.prop('disabled', true).text('Đang kiểm tra...');
                alertBox.removeClass('d-none alert-danger alert-success').addClass('alert-info');
                alertIcon.text('sync');
                alertMsg.text('Đang kết nối đến ' + provider + ' API...');

                $.ajax({
                    url: '@Url.Page("/SystemSettings/TestConnection")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ provider: provider, apiKey: apiKey, model: model }),
                    success: function (response) {
                        alertBox.removeClass('alert-info');
                        if (response.success) {
                            alertBox.addClass('alert-success').removeClass('alert-danger');
                            alertIcon.text('check_circle');
                        } else {
                            alertBox.addClass('alert-danger').removeClass('alert-success');
                            alertIcon.text('error');
                        }
                        alertMsg.text(response.message);
                    },
                    error: function () {
                        alertBox.removeClass('alert-info alert-success').addClass('alert-danger');
                        alertIcon.text('error');
                        alertMsg.text('Lỗi kết nối mạng đến server.');
                    },
                    complete: function () {
                        btn.prop('disabled', false).text('Kiểm tra kết nối ' + provider);
                    }
                });
            });
        });
    </script>
}
