@page "/RagasEvaluation/Index"
@model Presentation.Pages.RagasEvaluation.IndexModel

@{
    ViewData["Title"] = "Đánh giá chất lượng mô hình RAG";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-gray-800 fw-bold">Đánh giá chất lượng RAG (RAGAS)</h1>
            <p class="text-muted mb-0">Quản lý câu hỏi mẫu và đánh giá hiệu năng truy xuất của các môn học</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 font-weight-bold" style="color: var(--primary-color);">Danh sách môn học</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="border-0 px-4 py-3">Mã môn</th>
                            <th class="border-0 py-3">Tên môn học</th>
                            <th class="border-0 py-3 text-center">Số câu hỏi mẫu</th>
                            <th class="border-0 py-3 text-center">Số lượt chạy</th>
                            <th class="border-0 py-3 text-center">Điểm đánh giá gần nhất</th>
                            <th class="border-0 py-3">Thời gian chạy</th>
                            <th class="border-0 py-3 text-end px-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ViewModel.Subjects.Any())
                        {
                            foreach (var subject in Model.ViewModel.Subjects)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-semibold">@subject.SubjectCode</td>
                                    <td class="py-3">@subject.SubjectName</td>
                                    <td class="py-3 text-center">
                                        <span class="badge @(subject.QuestionCount > 0 ? "bg-primary" : "bg-secondary") rounded-pill px-3">
                                            @subject.QuestionCount
                                        </span>
                                    </td>
                                    <td class="py-3 text-center">@subject.BenchmarkRunCount</td>
                                    <td class="py-3 text-center">
                                        @if (subject.LastOverallScore.HasValue)
                                        {
                                            var score = subject.LastOverallScore.Value;
                                            var scoreClass = score >= 0.8m ? "text-success" : (score >= 0.5m ? "text-warning" : "text-danger");
                                            <span class="fw-bold @scoreClass fs-5">@score.ToString("P1")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Chưa có</span>
                                        }
                                    </td>
                                    <td class="py-3 text-muted small">
                                        @(subject.LastRunDate?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")
                                    </td>
                                    <td class="py-3 text-end px-4">
                                        <a asp-page="/RagasEvaluation/Questions" asp-route-subjectId="@subject.SubjectId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            Quản lý câu hỏi
                                        </a>
                                        @if (subject.BenchmarkRunCount > 0)
                                        {
                                            <a asp-page="/RagasEvaluation/Details" asp-route-subjectId="@subject.SubjectId" class="btn btn-sm btn-light text-primary rounded-pill ms-1">
                                                Xem kết quả
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">Không có môn học nào trong hệ thống.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


