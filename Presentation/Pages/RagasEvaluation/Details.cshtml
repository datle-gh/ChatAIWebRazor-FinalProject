</style>

@section Scripts {
    <script>
        document.querySelectorAll(".ragas-strategy-filter").forEach((select) => {
            select.addEventListener("change", () => {
                const panel = document.getElementById(select.dataset.panel);
                if (!panel) return;

                let visible = 0;
                panel.querySelectorAll(".ragas-result-item").forEach((item) => {
                    const show = !select.value || item.dataset.strategy === select.value;
                    item.hidden = !show;
                    if (show) visible += 1;
                });

                const emptyState = panel.querySelector(".ragas-filter-empty");
                if (emptyState) emptyState.hidden = visible !== 0;
            });
        });
    </script>
}
