        gap: 8px;
        height: 245px;
    }
    .metric-bar-slot { position: relative; height: 245px; }
    .metric-bar, .metric-value { position: absolute; left: 0; right: 0; bottom: 0; }
    .metric-bar { height: var(--metric-height); min-height: 2px; border-radius: 3px 3px 0 0; }
