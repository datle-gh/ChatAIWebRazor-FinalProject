    .metric-group-label strong, .metric-group-label span { display: block; }
    .metric-group-label span { color: #6c757d; font-size: .75rem; margin-top: 3px; }
    .metric-recall { background: #0d6efd; }
    .metric-mrr { background: #198754; }
    .metric-ndcg { background: #d97706; }
    .metric-correctness { background: #7c3aed; }
    .metric-faithfulness { background: #00897b; }
