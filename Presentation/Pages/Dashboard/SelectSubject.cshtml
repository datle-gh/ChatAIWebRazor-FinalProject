@page "/Dashboard/SelectSubject"
@model Presentation.Pages.Dashboard.SelectSubjectModel

@{
    ViewData["Title"] = "Chọn môn học để bắt đầu hỏi đáp";
    Layout = "_Layout";
}

<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "primary": "#3525cd",
                    "primary-container": "#4f46e5",
                    "primary-fixed": "#e2dfff",
                    "primary-fixed-dim": "#c3c0ff",
                    "on-primary": "#ffffff",
                    "secondary-container": "#d0e1fb",
                    "on-secondary-container": "#54647a",
                    "surface-container-lowest": "#ffffff",
                    "surface-container-low": "#f2f4f6",
                    "surface-container": "#eceef0",
                    "surface-container-high": "#e6e8ea",
                    "surface-tint": "#4d44e3",
                    "background": "#f7f9fb",
                    "on-surface": "#191c1e",
                    "on-surface-variant": "#464555",
                    "outline": "#777587",
                    "outline-variant": "#c7c4d8",
                    "error-container": "#ffdad6",
                }
            }
        }
    };
</script>

<div class="bg-background min-h-screen p-6 md:p-10">

    @* Page Header *@
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl md:text-4xl font-bold text-on-surface mb-2" style="font-family:'Be Vietnam Pro',sans-serif">
                Chọn môn học để bắt đầu hỏi đáp
            </h1>
            <p class="text-on-surface-variant" style="font-family:'Inter',sans-serif">
                Lựa chọn không gian tri thức để Gia sư AI có thể hỗ trợ bạn tốt nhất.
            </p>
        </div>
        <div class="relative w-full lg:max-w-md">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline" style="pointer-events:none">search</span>
            <input id="subjectSearch"
                   type="text"
                   placeholder="Tìm kiếm môn học hoặc mã môn..."
                   class="w-full pl-12 pr-4 py-3 rounded-xl border border-outline-variant bg-surface-container-lowest text-on-surface outline-none transition-all placeholder:text-outline"
                   style="font-family:'Inter',sans-serif;box-shadow:0 2px 6px rgba(79,70,229,0.06)"
                   oninput="filterSubjects(this.value)" />
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div class="flex items-center gap-3 px-5 py-3 rounded-xl border text-sm mb-5"
             style="background:#e2dfff;border-color:#c3c0ff;color:#3525cd;font-family:'Inter',sans-serif">
            <span class="material-symbols-outlined text-[18px]">check_circle</span>
            @successMsg
        </div>
    }
    @if (TempData["ErrorMessage"] is string errorMsg)
    {
        <div class="flex items-center gap-3 px-5 py-3 rounded-xl border text-sm mb-5"
             style="background:#ffdad6;border-color:#ffb4ab;color:#ba1a1a;font-family:'Inter',sans-serif">
            <span class="material-symbols-outlined text-[18px]">error</span>
            @SanitizeErrorMessage(errorMsg)
        </div>
    }

    @if (Model.ViewModel.ShowTeacherFilters)
    {
        <div class="flex flex-wrap items-center gap-2 mb-6" style="font-family:'Inter',sans-serif">
            <a asp-page="/Dashboard/SelectSubject" asp-route-filter="enrolled"
               class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border text-sm font-semibold transition-all @(Model.ViewModel.SelectedFilter == "enrolled" ? "bg-primary-container text-white border-primary-container shadow-sm" : "bg-surface-container-lowest text-on-surface-variant border-outline-variant hover:border-primary-container hover:text-primary")"
               style="text-decoration:none">
                <span class="material-symbols-outlined text-[18px]">how_to_reg</span>
                Đang tham gia
            </a>
            <a asp-page="/Dashboard/SelectSubject" asp-route-filter="created"
               class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border text-sm font-semibold transition-all @(Model.ViewModel.SelectedFilter == "created" ? "bg-primary-container text-white border-primary-container shadow-sm" : "bg-surface-container-lowest text-on-surface-variant border-outline-variant hover:border-primary-container hover:text-primary")"
               style="text-decoration:none">
                <span class="material-symbols-outlined text-[18px]">edit_square</span>
                Đã tạo
            </a>
            <a asp-page="/Dashboard/SelectSubject" asp-route-filter="all"
               class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border text-sm font-semibold transition-all @(Model.ViewModel.SelectedFilter == "all" ? "bg-primary-container text-white border-primary-container shadow-sm" : "bg-surface-container-lowest text-on-surface-variant border-outline-variant hover:border-primary-container hover:text-primary")"
               style="text-decoration:none">
                <span class="material-symbols-outlined text-[18px]">apps</span>
                Tất cả môn học
            </a>
        </div>
    }

    @if (!Model.ViewModel.Subjects.Any())
    {
        <div class="bg-surface-container-lowest rounded-2xl p-16 text-center border border-surface-container-high">
            <span class="material-symbols-outlined text-on-surface-variant mb-4 block" style="font-size:56px">school</span>
            <h2 class="text-xl font-semibold text-on-surface mb-2" style="font-family:'Be Vietnam Pro',sans-serif">Chưa có môn học nào</h2>
            <p class="text-on-surface-variant" style="font-family:'Inter',sans-serif">Hãy liên hệ giảng viên để được thêm vào môn học.</p>
        </div>
    }
    else
    {
        @* Subjects Grid *@
        <div id="subjectGrid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            @foreach (var subject in Model.ViewModel.Subjects)
            {
                <div class="subject-card bg-surface-container-lowest rounded-2xl p-6 border flex flex-col transition-all duration-200 @(subject.IsReady ? "hover:border-primary-fixed-dim hover:shadow-md group" : "opacity-80")"
                     data-name="@subject.SubjectName.ToLower()" data-code="@subject.SubjectCode.ToLower()"
                     style="border-color:@(subject.IsReady ? "#c7c4d8" : "#e6e8ea");box-shadow:0 4px 12px rgba(79,70,229,0.04)">

                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <span class="inline-block px-2.5 py-1 rounded text-xs font-semibold uppercase tracking-wider mb-3"
                                  style="@(subject.IsReady ? "background:#d0e1fb;color:#54647a" : "background:#eceef0;color:#777587");font-family:'Inter',sans-serif">
                                @subject.SubjectCode
                            </span>
                            <h3 class="text-lg font-semibold @(subject.IsReady ? "text-on-surface group-hover:text-primary" : "text-on-surface-variant") transition-colors"
                                style="font-family:'Be Vietnam Pro',sans-serif">
                                @subject.SubjectName
                            </h3>
                        </div>
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
                             style="@(subject.IsReady ? "background:rgba(79,70,229,0.1);color:#4f46e5" : "background:#e6e8ea;color:#777587")">
                            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' @(subject.IsReady ? "1" : "0")">
                                @(subject.IsReady ? "database" : "lock")
                            </span>
                        </div>
                    </div>

                    @if (subject.IsReady)
                    {
                        <div class="flex items-center gap-2 mb-6 text-sm text-on-surface-variant" style="font-family:'Inter',sans-serif">
                            <span class="material-symbols-outlined text-[18px]" style="color:#c3c0ff">library_books</span>
                            <span>@subject.IndexedDocumentCount tài liệu đã index</span>
                        </div>
                        @if (User.IsInRole("Student") && !subject.IsEnrolled)
                        {
                            <form asp-page="/Dashboard/JoinSubject" method="post" class="mt-auto">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="subjectId" value="@subject.Id" />
                                <button type="submit"
                                        class="w-full flex justify-center items-center gap-2 py-3 rounded-xl font-semibold text-white transition-all duration-200 active:scale-95 shadow-sm border-0"
                                        style="background:#4f46e5;font-family:'Inter',sans-serif">
                                    <span class="material-symbols-outlined text-[18px]">person_add</span>
                                    Tham gia
                                </button>
                            </form>
                        }
                        else
                        {
                        <a asp-page="/Chat/Index" asp-route-subjectId="@subject.Id"
                           class="mt-auto w-full flex justify-center items-center gap-2 py-3 rounded-xl font-semibold text-white transition-all duration-200 active:scale-95 shadow-sm"
                           style="background:#4f46e5;font-family:'Inter',sans-serif;text-decoration:none">
                            <span class="material-symbols-outlined text-[18px]">forum</span>
                            Hỏi chatbot
                        </a>
                        }
                    }
                    else
                    {
                        <div class="bg-surface-container p-3 rounded-xl border border-outline-variant mb-6 flex gap-3 items-start"
                             style="font-family:'Inter',sans-serif">
                            <span class="material-symbols-outlined text-outline text-[20px] mt-0.5">info</span>
                            <p class="text-sm text-on-surface-variant">Môn học này chưa có tài liệu được index.</p>
                        </div>
                        <button class="mt-auto w-full flex justify-center items-center gap-2 py-3 rounded-xl font-semibold cursor-not-allowed"
                                style="background:#e6e8ea;color:#777587;border:1px solid #c7c4d8;font-family:'Inter',sans-serif"
                                disabled>
                            <span class="material-symbols-outlined text-[18px]">lock</span>
                            Chưa sẵn sàng
                        </button>
                    }
                </div>
            }
        </div>

        <div id="noResults" class="hidden bg-surface-container-lowest rounded-2xl p-12 text-center border border-surface-container-high">
            <span class="material-symbols-outlined text-on-surface-variant mb-3 block" style="font-size:40px">search_off</span>
            <p class="text-on-surface-variant" style="font-family:'Inter',sans-serif">Không tìm thấy môn học phù hợp.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterSubjects(query) {
            const q = query.toLowerCase().trim();
            const cards = document.querySelectorAll('.subject-card');
            let visible = 0;
            cards.forEach(card => {
                const name = card.dataset.name || '';
                const code = card.dataset.code || '';
                const match = !q || name.includes(q) || code.includes(q);
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            const noResults = document.getElementById('noResults');
            if (noResults) noResults.classList.toggle('hidden', visible > 0);
        }
    </script>
}

@functions {
    private static string SanitizeErrorMessage(string message)
    {
        return IsTechnicalError(message)
            ? "Có lỗi khi xử lý tài liệu. Vui lòng thử lại hoặc liên hệ giảng viên."
            : message;
    }

    private static bool IsTechnicalError(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        return message.Contains("entity type", StringComparison.OrdinalIgnoreCase)
            || message.Contains("same key value", StringComparison.OrdinalIgnoreCase)
            || message.Contains("DbContext", StringComparison.OrdinalIgnoreCase)
            || message.Contains("System.", StringComparison.OrdinalIgnoreCase)
            || message.Contains("Microsoft.", StringComparison.OrdinalIgnoreCase);
    }
}


